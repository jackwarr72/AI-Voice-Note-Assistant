{
  "entities": {
    "VoiceNote": {
      "title": "Voice Note",
      "description": "A processed voice note with transcription and insights.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "remoteJid": { "type": "string", "description": "The WhatsApp JID of the sender." },
        "filename": { "type": "string" },
        "transcript": { "type": "string" },
        "insights": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "key_points": { "type": "array", "items": { "type": "string" } },
            "questions": { "type": "array", "items": { "type": "string" } },
            "suggested_replies": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "filename", "transcript", "insights", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email", "displayName", "photoURL", "role"]
    },
    "WhatsAppSession": {
      "title": "WhatsApp Session",
      "description": "Stores WhatsApp authentication data for persistence.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionData": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sessionData", "updatedAt"]
    },
    "PendingTranscription": {
      "title": "Pending Transcription",
      "description": "Audio received from WhatsApp waiting for transcription.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "remoteJid": { "type": "string" },
        "audioBase64": { "type": "string" },
        "mimeType": { "type": "string" },
        "filename": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "audioBase64", "mimeType", "filename", "createdAt"]
    }
  },
  "firestore": {
    "/voice_notes/{noteId}": {
      "schema": "VoiceNote",
      "description": "Collection of processed voice notes."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/whatsapp_sessions/{userId}": {
      "schema": "WhatsAppSession",
      "description": "Stores encrypted WhatsApp session data."
    },
    "/pending_transcriptions/{transcriptionId}": {
      "schema": "PendingTranscription",
      "description": "Queue for incoming WhatsApp audio messages."
    }
  }
}
